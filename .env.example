APP_NAME="COFIBANK"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cofibank
DB_USERNAME=root
DB_PASSWORD=

# Service Python (Oracle)
PYTHON_SERVICE_URL=http://localhost:8001

# Durée de cache des réponses Oracle côté Laravel (secondes). 0 = désactivé.
ORACLE_DATA_CACHE_TTL=300

