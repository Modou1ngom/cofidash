# Copier vers .env et renseigner les secrets (ne pas committer .env)

# Oracle principal (reporting) — surcharge optionnelle des valeurs par défaut
# ORACLE_HOST=
# ORACLE_PORT=
# ORACLE_SERVICE_NAME=
# ORACLE_USERNAME=
# ORACLE_PASSWORD=

# Oracle Cofina (REPORT_GROUPE)
ORACLE_COFINA_HOST=
ORACLE_COFINA_PORT=
ORACLE_COFINA_SERVICE_NAME=
ORACLE_COFINA_USERNAME=
# Mettre entre quotes simples si # ou $ dans le mot de passe
ORACLE_COFINA_PASSWORD=''

# Collecte (domiciliation) — si ORA-00942 : un seul schéma pour les 3 tables
# ORACLE_DASH_SCHEMA=OWNER_QUI_CONTIENT_LES_DASH
# ou chaque table : ORACLE_DASH_ETAT_CPT_TABLE=OWNER.DASH_ETAT_CPT
# Réponse 500 au lieu de zéros : ORACLE_DOMICILIATION_ORA942_EMPTY=0
