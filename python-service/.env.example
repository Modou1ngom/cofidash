# Copier vers .env et renseigner les secrets (ne pas committer .env)

# Oracle principal (reporting) — surcharge optionnelle des valeurs par défaut
# ORACLE_HOST=
# ORACLE_PORT=
# ORACLE_SERVICE_NAME=
# ORACLE_USERNAME=
# ORACLE_PASSWORD=

# Oracle Cofina (REPORT_GROUPE)
ORACLE_COFINA_HOST=
ORACLE_COFINA_PORT=
ORACLE_COFINA_SERVICE_NAME=
ORACLE_COFINA_USERNAME=
# Mettre entre quotes simples si # ou $ dans le mot de passe
ORACLE_COFINA_PASSWORD=''

# Collecte (domiciliation) — uniquement si les tables ne sont pas visibles (ORA-00942)
# ORACLE_DASH_ETAT_CPT_TABLE=SCHEMA.DASH_ETAT_CPT
# ORACLE_DASH_TOMBE_MOIS_TABLE=SCHEMA.DASH_TOMBE_MOIS
# ORACLE_DASH_EXIGIBLE_TABLE=SCHEMA.DASH_EXIGIBLE
